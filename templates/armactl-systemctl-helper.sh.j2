#!/bin/sh
# Narrow root-owned helper for armactl systemctl actions.

INSTALL_BIN="{{ install_bin }}"
SYSTEMCTL_BIN="{{ systemctl_bin }}"

if [ "$#" -lt 1 ]; then
    printf '%s\n' "Usage: armactl-systemctl-helper ACTION [UNIT]" >&2
    exit 1
fi

action="$1"
shift

case "$action" in
    start|stop|restart|enable|disable)
        if [ "$#" -ne 1 ]; then
            printf '%s\n' "Usage: armactl-systemctl-helper $action UNIT" >&2
            exit 1
        fi

        unit_name="$1"
        case "$unit_name" in
            armareforger.service|armareforger@*.service|\
            armareforger-restart.service|armareforger-restart.timer|\
            armareforger-restart@*.service|armareforger-restart@*.timer|\
            armactl-bot.service)
                exec "$SYSTEMCTL_BIN" "$action" "$unit_name"
                ;;
            *)
                printf "Denied: unsupported unit '%s'.\n" "$unit_name" >&2
                exit 1
                ;;
        esac
        ;;

    daemon-reload)
        if [ "$#" -ne 0 ]; then
            printf '%s\n' "Denied: daemon-reload does not accept a unit argument." >&2
            exit 1
        fi
        exec "$SYSTEMCTL_BIN" daemon-reload
        ;;

    update-timer)
        if [ "$#" -lt 2 ]; then
            printf '%s\n' \
                "Usage: armactl-systemctl-helper update-timer TIMER_NAME ONCALENDAR..." >&2
            exit 1
        fi

        timer_name="$1"
        shift
        case "$timer_name" in
            armareforger-restart.timer|armareforger-restart@*.timer)
                ;;
            *)
                printf "Denied: unsupported timer '%s'.\n" "$timer_name" >&2
                exit 1
                ;;
        esac

        tmp_file=`mktemp` || {
            printf '%s\n' "Failed to allocate temporary file." >&2
            exit 1
        }

        {
            printf '%s\n' "[Unit]"
            printf '%s\n' "Description=Scheduled restart for Arma Reforger Dedicated Server"
            printf '\n'
            printf '%s\n' "[Timer]"
        } > "$tmp_file" || exit 1

        for entry in "$@"; do
            if [ -z "$entry" ]; then
                rm -f "$tmp_file"
                printf '%s\n' "Denied: invalid OnCalendar entry." >&2
                exit 1
            fi
            printf 'OnCalendar=%s\n' "$entry" >> "$tmp_file" || exit 1
        done

        {
            printf '%s\n' "Persistent=true"
            printf '\n'
            printf '%s\n' "[Install]"
            printf '%s\n' "WantedBy=timers.target"
        } >> "$tmp_file" || exit 1

        "$INSTALL_BIN" -D -o root -g root -m 0644 \
            "$tmp_file" "/etc/systemd/system/$timer_name"
        rc="$?"
        rm -f "$tmp_file"
        exit "$rc"
        ;;

    *)
        printf "Denied: unsupported action '%s'.\n" "$action" >&2
        exit 1
        ;;
esac
