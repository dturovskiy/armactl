#!/usr/bin/env bash
set -euo pipefail

INSTANCE_ROOT="{{ instance_root }}"
SERVER_DIR="{{ server_dir }}"
CONFIG_DIR="{{ config_dir }}"
CONFIG_FILE="{{ config_file }}"

cd "${SERVER_DIR}"

exec "${SERVER_DIR}/ArmaReforgerServer" \
  -config "${CONFIG_FILE}" \
  -profile "${CONFIG_DIR}" \
  -maxFPS {{ max_fps | default(60) }}
