# Example Telegram bot configuration for armactl.
# This file is only an example for the repository.
#
# Runtime source of truth:
#   ~/armactl-data/<instance>/bot/.env
#
# The future TUI bot setup screen should read and write the same file.

ARMACTL_BOT_ENABLED=false
ARMACTL_BOT_TOKEN=
ARMACTL_BOT_ADMIN_CHAT_IDS=
ARMACTL_BOT_LANGUAGE=uk
ARMACTL_INSTANCE=default
