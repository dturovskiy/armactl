#!/bin/sh
# Convenience launcher for the armactl TUI.
# Usage: ./scripts/run-tui

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PROJECT_ROOT=$(dirname -- "$SCRIPT_DIR")
VENV_ARM="$PROJECT_ROOT/.venv/bin/armactl"

if [ ! -x "$VENV_ARM" ]; then
    printf 'armactl not installed. Run first:\n  ./scripts/bootstrap.sh\n' >&2
    exit 1
fi

# Placeholder — will launch TUI once implemented
printf 'armactl TUI is not yet implemented.\nUse: armactl --help\n'
